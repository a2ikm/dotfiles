#!/bin/sh

set -eux

export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

dotfiles_dir="$(cd "$( dirname "$0" )" && pwd)"

link() {
  mkdir -p $(dirname "$2")
  ln -sf "$dotfiles_dir/$1" "$2"
}

mkdir -p ~/bin
mkdir -p ~/.config

link bin/kexec ~/bin/kexec
link bin/git-sweep ~/bin/git-sweep
link bin/git-m ~/bin/git-m
link bin/git-tree ~/bin/git-tree

link git/config "$XDG_CONFIG_HOME/git/config"
link git/ignore "$XDG_CONFIG_HOME/git/ignore"
link ghostty/config "$XDG_CONFIG_HOME/ghostty/config"
link irb/irbrc "$XDG_CONFIG_HOME/irb/irbrc"
link tig/config "$XDG_CONFIG_HOME/tig/config"
link vim/vimrc "$XDG_CONFIG_HOME/vim/vimrc"
link tmux/tmux.conf "$XDG_CONFIG_HOME/tmux/tmux.conf"

link screen/screenrc ~/.screenrc
link zsh/zshrc ~/.zshrc

link claude/settings.json ~/.claude/settings.json
link claude/CLAUDE.md ~/.claude/CLAUDE.md

case "$(uname)" in
  Darwin)
    if [ -z "$(type brew)" ]; then
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    brew install \
      awscli \
      colordiff \
      peco \
      gh \
      ghq \
      git \
      go \
      graphviz \
      grep \
      jq \
      kubectl \
      libyaml \
      nkf \
      openjdk \
      openssl@1.1 \
      readline \
      ripgrep \
      stern \
      tig \
      tmux \
      yq

    ln -sf /opt/homebrew/share/git-core/contrib/diff-highlight/diff-highlight ~/bin/diff-highlight
    sudo ln -sfn /opt/homebrew/opt/openjdk/libexec/openjdk.jdk /Library/Java/JavaVirtualMachines/openjdk.jdk

    link git/config.darwin "$XDG_CONFIG_HOME/git/config.local"
    ;;
  Linux)
    link git/config.linux "$XDG_CONFIG_HOME/git/config.local"

    if [ -f  /usr/share/doc/git/contrib/diff-highlight/diff-highlight ]; then
      sudo ln -sf /usr/share/doc/git/contrib/diff-highlight/diff-highlight /usr/local/bin/diff-highlight
    elif [ -d  /usr/share/doc/git/contrib/diff-highlight ]; then
      cd /usr/share/doc/git/contrib/diff-highlight
      sudo make
      sudo ln -sf /usr/share/doc/git/contrib/diff-highlight/diff-highlight /usr/local/bin/diff-highlight
    fi

    sudo apt update
    sudo apt install -y \
      zsh \
      less \
      nkf \
      tig \
      ripgrep \
      vim \
      locales-all \
      jq \
      gh \
      nodejs \
      npm \
      tmux


    if !(type claude >/dev/null 2>&1); then
      curl -fsSL https://claude.ai/install.sh | bash
    fi

    if !(type peco >/dev/null 2>&1); then
      case "$(uname -m)" in
        x86_64)  peco_arch="amd64" ;;
        aarch64) peco_arch="arm64" ;;
        armv7l)  peco_arch="arm" ;;
        i386|i686) peco_arch="386" ;;
        *) echo "unsupported architecture for peco: $(uname -m)"; exit 1 ;;
      esac

      peco_url="$(curl -fsSL https://api.github.com/repos/peco/peco/releases/latest \
        | jq -r ".assets[] | select(.name == \"peco_linux_${peco_arch}.tar.gz\") | .browser_download_url")"

      peco_tmp="$(mktemp -d)"
      curl -fsSL "$peco_url" -o "$peco_tmp/peco.tar.gz"
      tar -xzf "$peco_tmp/peco.tar.gz" -C "$peco_tmp"
      mv "$peco_tmp/peco_linux_${peco_arch}/peco" ~/bin/peco
      chmod +x ~/bin/peco
      rm -rf "$peco_tmp"
    fi
    ;;
  *)
    echo "unsupported platform: $(uname)"
    ;;
esac

if [ ! -d ~/.rbenv ]; then
  git clone https://github.com/rbenv/rbenv.git ~/.rbenv
fi

if [ ! -d ~/.rbenv/plugins/ruby-build ]; then
  mkdir -p ~/.rbenv/plugins
  git clone https://github.com/rbenv/ruby-build.git ~/.rbenv/plugins/ruby-build
fi
